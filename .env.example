# Copy to .env and fill in API keys:
#   cp .env.example .env
#
# Variable names must match sites.json → sites.<id>.api_key_env

BAI_API_KEY=sk-your-bai-api-key

# Optional: override Codex binary path (auto-detected if unset)
# CODEX_BIN=/Applications/Codex.app/Contents/Resources/codex

# Optional: SOCKS/HTTP proxy for upstream API (auto-detects v2rayN 10808 if unset)
# Use socks5h so DNS resolves through the proxy (avoids polluted local DNS).
# MAAS_PROXY=socks5h://127.0.0.1:10808
# MAAS_PROXY_SKIP=1
